{
  "TCP": {
    "443": {
      "HTTPS": true
    },
    "8100": {
      "HTTPS": true
    }
  },
  "Web": {
    "${TS_CERT_DOMAIN}:443": {
      "Handlers": {
        "/": {
          "Proxy": "http://127.0.0.1:4443"
        }
      }
    },
    "${TS_CERT_DOMAIN}:8100": {
      "Handlers": {
        "/": {
          "Proxy": "http://127.0.0.1:8100"
        }
      }
    }
  },
  "AllowFunnel": {
    "${TS_CERT_DOMAIN}:443": false,
    "${TS_CERT_DOMAIN}:8100": false
  }
}
